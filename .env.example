# ha-smartshift environment variables
# Copy this to .env and fill in your values

# Inverter settings (defaults shown)
INVERTER_URL=https://10.0.0.6
INVERTER_SN=OE012K01Z2610013

# Amber Electric API key (optional - falls back to AEMO public data if not set)
# Get your key from https://app.amber.com.au/developers
AMBER_API_KEY=

# NSW state for Amber API
AMBER_STATE=NSW

# Decision thresholds (cents/kWh)
CHARGE_THRESHOLD=5
DISCHARGE_THRESHOLD=25

# Battery safety limits (%)
SOC_MIN=20
SOC_MAX=95

# State file path (for HA sensor to read)
STATE_FILE=/home/bowen/ha-smartshift/.current_state.json
